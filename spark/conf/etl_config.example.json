{
  "spark": {
    "app_name_batch": "movie-postgres-to-hive-ods",
    "app_name_streaming": "movie-kafka-to-hive-ods",
    "master": "yarn",
    "warehouse_dir": "hdfs:///warehouse/tablespace/external/hive",
    "shuffle_partitions": 400,
    "checkpoint_root": "hdfs:///warehouse/checkpoints/movie-etl",
    "trigger_processing_time": "30 seconds"
  },
  "postgres": {
    "jdbc_url": "jdbc:postgresql://127.0.0.1:5432/movie",
    "user": "movie_user",
    "password": "movie_password",
    "driver": "org.postgresql.Driver",
    "fetch_size": 10000,
    "tables": [
      {
        "source_table": "public.movies",
        "target_table": "ods.ods_pg_movies_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/movies",
        "partition_column": "movie_id",
        "lower_bound": 1,
        "upper_bound": 2000000,
        "num_partitions": 24
      },
      {
        "source_table": "public.users",
        "target_table": "ods.ods_pg_users_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/users"
      },
      {
        "source_table": "public.ratings",
        "target_table": "ods.ods_pg_ratings_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/ratings"
      },
      {
        "source_table": "public.comments",
        "target_table": "ods.ods_pg_comments_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/comments"
      },
      {
        "source_table": "public.comment_likes",
        "target_table": "ods.ods_pg_comment_likes_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/comment_likes"
      },
      {
        "source_table": "public.favorite_folders",
        "target_table": "ods.ods_pg_favorite_folders_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/favorite_folders"
      },
      {
        "source_table": "public.favorites",
        "target_table": "ods.ods_pg_favorites_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/favorites"
      },
      {
        "source_table": "public.view_history",
        "target_table": "ods.ods_pg_view_history_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/view_history"
      },
      {
        "source_table": "public.watched_movies",
        "target_table": "ods.ods_pg_watched_movies_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/watched_movies"
      }
    ]
  },
  "kafka": {
    "bootstrap_servers": "127.0.0.1:9092",
    "topics": [
      "movie-view-history",
      "movie-rating-events",
      "movie-comment-events",
      "movie-comment-like-events",
      "movie-favorite-events",
      "movie-watched-events",
      "movie-favorite-folder-action-events",
      "movie-search-events",
      "movie-user-register-events",
      "movie-user-login-events"
    ],
    "starting_offsets": "latest",
    "fail_on_data_loss": false,
    "max_offsets_per_trigger": 50000,
    "sink_table": "ods.ods_kafka_event_log_di",
    "sink_path": "hdfs:///warehouse/movie/ods/kafka/event_log"
  },
  "dwd": {
    "source_tables": {
      "events": "ods.ods_kafka_event_log_di",
      "users": "ods.ods_pg_users_full",
      "movies": "ods.ods_pg_movies_full",
      "comments": "ods.ods_pg_comments_full",
      "favorite_folders": "ods.ods_pg_favorite_folders_full",
      "ratings": "ods.ods_pg_ratings_full"
    },
    "target_table": "dwd.dwd_user_event_wide_di",
    "sink_path": "hdfs:///warehouse/movie/dwd/user_event_wide_di"
  },
  "dws": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_tables": {
      "user_action_1d": "dws.dws_user_action_1d",
      "movie_action_1d": "dws.dws_movie_action_1d",
      "event_type_1d": "dws.dws_event_type_1d"
    },
    "sink_paths": {
      "user_action_1d": "hdfs:///warehouse/movie/dws/user_action_1d",
      "movie_action_1d": "hdfs:///warehouse/movie/dws/movie_action_1d",
      "event_type_1d": "hdfs:///warehouse/movie/dws/event_type_1d"
    },
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "favorite_add_cnt": 1.2,
      "watched_cnt": 2.5
    }
  },
  "ads": {
    "source_table": "dws.dws_movie_action_1d",
    "target_table": "ads.ads_hot_movies",
    "sink_path": "hdfs:///warehouse/movie/ads/hot_movies",
    "period_days": {
      "DAILY": 1,
      "WEEKLY": 7,
      "MONTHLY": 30
    },
    "top_n": 100,
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "comment_like_cnt": 0.8,
      "favorite_add_cnt": 1.2,
      "favorite_remove_cnt": -0.8,
      "watched_cnt": 2.5,
      "active_user_cnt": 1.0
    }
  },
  "ads_user_funnel": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_user_funnel_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/user_funnel_1d"
  },
  "ads_user_retention": {
    "register_source_table": "dwd.dwd_user_event_wide_di",
    "active_source_table": "dws.dws_user_action_1d",
    "target_table": "ads.ads_user_retention",
    "sink_path": "hdfs:///warehouse/movie/ads/user_retention",
    "retention_days": [1, 7, 30]
  },
  "ads_genre_preference": {
    "source_table": "dws.dws_movie_action_1d",
    "target_table": "ads.ads_genre_preference_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/genre_preference_1d",
    "top_n": 100
  },
  "ads_itemcf": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_tables": {
      "similar_movies": "ads.ads_itemcf_similar_movies",
      "user_recommendations": "ads.ads_itemcf_user_recommendations"
    },
    "sink_paths": {
      "similar_movies": "hdfs:///warehouse/movie/ads/itemcf_similar_movies",
      "user_recommendations": "hdfs:///warehouse/movie/ads/itemcf_user_recommendations"
    },
    "lookback_days": 90,
    "min_user_item_score": 0.1,
    "min_co_users": 2,
    "shrinkage": 10.0,
    "top_k_similar": 100,
    "top_n_recommend": 30,
    "event_score_weights": {
      "view": 1.0,
      "favorite": 2.0,
      "comment": 2.0,
      "rating": 3.0,
      "watched": 3.0,
      "rating_value": 2.0
    }
  },
  "ads_reco_user_item_features": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_reco_user_item_features_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/reco_user_item_features_1d",
    "lookback_days": 30,
    "min_feature_score": 0.1,
    "event_score_weights": {
      "view": 1.0,
      "favorite_add": 2.0,
      "favorite_remove": -1.0,
      "comment": 2.0,
      "rating": 3.0,
      "watched": 3.0,
      "rating_value": 2.0
    }
  },
  "ads_search_keyword_insights": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_search_keyword_insights_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/search_keyword_insights_1d",
    "top_n": 200,
    "min_search_cnt": 5
  },
  "ads_search_funnel": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_search_funnel_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/search_funnel_1d"
  }
}
