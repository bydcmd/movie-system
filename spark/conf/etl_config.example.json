{
  "spark": {
    "app_name_batch": "movie-postgres-to-hive-ods",
    "app_name_streaming": "movie-kafka-to-hive-ods",
    "master": "yarn",
    "warehouse_dir": "hdfs:///warehouse/tablespace/external/hive",
    "shuffle_partitions": 400,
    "checkpoint_root": "hdfs:///warehouse/checkpoints/movie-etl",
    "trigger_processing_time": "30 seconds"
  },
  "postgres": {
    "jdbc_url": "jdbc:postgresql://127.0.0.1:5432/movie",
    "user": "movie_user",
    "password": "movie_password",
    "driver": "org.postgresql.Driver",
    "fetch_size": 10000,
    "tables": [
      {
        "source_table": "public.movies",
        "target_table": "ods.ods_pg_movies_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/movies",
        "partition_column": "movie_id",
        "lower_bound": 1,
        "upper_bound": 2000000,
        "num_partitions": 24
      },
      {
        "source_table": "public.users",
        "target_table": "ods.ods_pg_users_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/users"
      },
      {
        "source_table": "public.ratings",
        "target_table": "ods.ods_pg_ratings_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/ratings"
      },
      {
        "source_table": "public.comments",
        "target_table": "ods.ods_pg_comments_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/comments"
      },
      {
        "source_table": "public.comment_likes",
        "target_table": "ods.ods_pg_comment_likes_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/comment_likes"
      },
      {
        "source_table": "public.favorite_folders",
        "target_table": "ods.ods_pg_favorite_folders_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/favorite_folders"
      },
      {
        "source_table": "public.favorites",
        "target_table": "ods.ods_pg_favorites_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/favorites"
      },
      {
        "source_table": "public.view_history",
        "target_table": "ods.ods_pg_view_history_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/view_history"
      },
      {
        "source_table": "public.watched_movies",
        "target_table": "ods.ods_pg_watched_movies_full",
        "sink_path": "hdfs:///warehouse/movie/ods/postgres/watched_movies"
      }
    ]
  },
  "kafka": {
    "bootstrap_servers": "127.0.0.1:9092",
    "topics": [
      "movie-view-history",
      "movie-rating-events",
      "movie-comment-events",
      "movie-comment-like-events",
      "movie-favorite-events",
      "movie-watched-events",
      "movie-favorite-folder-action-events",
      "movie-search-events",
      "movie-user-register-events",
      "movie-user-login-events"
    ],
    "starting_offsets": "latest",
    "fail_on_data_loss": false,
    "max_offsets_per_trigger": 50000,
    "sink_table": "ods.ods_kafka_event_log_di",
    "sink_path": "hdfs:///warehouse/movie/ods/kafka/event_log"
  },
  "dwd": {
    "source_tables": {
      "events": "ods.ods_kafka_event_log_di",
      "users": "ods.ods_pg_users_full",
      "movies": "ods.ods_pg_movies_full",
      "comments": "ods.ods_pg_comments_full",
      "favorite_folders": "ods.ods_pg_favorite_folders_full",
      "ratings": "ods.ods_pg_ratings_full"
    },
    "target_table": "dwd.dwd_user_event_wide_di",
    "sink_path": "hdfs:///warehouse/movie/dwd/user_event_wide_di"
  },
  "dwd_user_snapshot": {
    "source_table": "ods.ods_pg_users_full",
    "target_table": "dwd.dwd_user_snapshot_di",
    "sink_path": "hdfs:///warehouse/movie/dwd/user_snapshot_di"
  },
  "dwd_movie_snapshot": {
    "source_table": "ods.ods_pg_movies_full",
    "target_table": "dwd.dwd_movie_snapshot_di",
    "sink_path": "hdfs:///warehouse/movie/dwd/movie_snapshot_di"
  },
  "dws": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_tables": {
      "user_action_1d": "dws.dws_user_action_1d",
      "movie_action_1d": "dws.dws_movie_action_1d",
      "event_type_1d": "dws.dws_event_type_1d"
    },
    "sink_paths": {
      "user_action_1d": "hdfs:///warehouse/movie/dws/user_action_1d",
      "movie_action_1d": "hdfs:///warehouse/movie/dws/movie_action_1d",
      "event_type_1d": "hdfs:///warehouse/movie/dws/event_type_1d"
    },
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "favorite_add_cnt": 1.2,
      "watched_cnt": 2.5
    }
  },
  "dws_profiles": {
    "source_tables": {
      "user_snapshot": "dwd.dwd_user_snapshot_di",
      "movie_snapshot": "dwd.dwd_movie_snapshot_di",
      "user_action": "dws.dws_user_action_1d",
      "movie_action": "dws.dws_movie_action_1d"
    },
    "target_tables": {
      "user_profile_1d": "dws.dws_user_profile_1d",
      "movie_profile_1d": "dws.dws_movie_profile_1d"
    },
    "sink_paths": {
      "user_profile_1d": "hdfs:///warehouse/movie/dws/user_profile_1d",
      "movie_profile_1d": "hdfs:///warehouse/movie/dws/movie_profile_1d"
    },
    "user_activity_score_weights": {
      "view_cnt": 1.0,
      "rating_cnt": 3.0,
      "comment_cnt": 3.0,
      "comment_like_cnt": 0.5,
      "favorite_add_cnt": 2.0,
      "favorite_remove_cnt": -1.0,
      "watched_cnt": 3.0,
      "search_cnt": 1.0,
      "login_cnt": 0.5,
      "favorite_folder_action_cnt": 1.5
    },
    "user_activity_level_thresholds": {
      "high": 20.0,
      "medium": 5.0
    },
    "movie_popularity_level_thresholds": {
      "hot": 1000.0,
      "warm": 100.0
    }
  },
  "dws_postgres_interactions": {
    "source_tables": {
      "movie_snapshot": "dwd.dwd_movie_snapshot_di",
      "ratings": "ods.ods_pg_ratings_full",
      "comments": "ods.ods_pg_comments_full",
      "comment_likes": "ods.ods_pg_comment_likes_full",
      "favorites": "ods.ods_pg_favorites_full",
      "view_history": "ods.ods_pg_view_history_full",
      "watched_movies": "ods.ods_pg_watched_movies_full"
    },
    "target_tables": {
      "user_item_preference_1d": "dws.dws_user_item_preference_1d",
      "movie_engagement_1d": "dws.dws_movie_engagement_1d",
      "movie_engagement_daily_1d": "dws.dws_movie_engagement_daily_1d"
    },
    "sink_paths": {
      "user_item_preference_1d": "hdfs:///warehouse/movie/dws/user_item_preference_1d",
      "movie_engagement_1d": "hdfs:///warehouse/movie/dws/movie_engagement_1d",
      "movie_engagement_daily_1d": "hdfs:///warehouse/movie/dws/movie_engagement_daily_1d"
    },
    "preference_score_weights": {
      "view": 1.0,
      "favorite_add": 2.0,
      "comment": 2.0,
      "rating": 3.0,
      "watched": 3.0,
      "rating_value": 2.0
    },
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "comment_like_cnt": 0.8,
      "favorite_add_cnt": 1.2,
      "favorite_remove_cnt": -0.8,
      "watched_cnt": 2.5,
      "active_user_cnt": 1.0
    }
  },
  "ads": {
    "source_table": "dws.dws_movie_engagement_daily_1d",
    "source_type": "movie_metric_daily",
    "target_table": "ads.ads_hot_movies",
    "sink_path": "hdfs:///warehouse/movie/ads/hot_movies",
    "period_days": {
      "DAILY": 1,
      "WEEKLY": 7,
      "MONTHLY": 30,
      "TOTAL": null
    },
    "top_n": 100,
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "comment_like_cnt": 0.8,
      "favorite_add_cnt": 1.2,
      "favorite_remove_cnt": -0.8,
      "watched_cnt": 2.5,
      "active_user_cnt": 1.0
    }
  },
  "ads_hot_movies_postgres_sync": {
    "source_table": "ads.ads_hot_movies",
    "target_table": "public.stats_hot_movies",
    "supported_period_types": [
      "DAILY",
      "WEEKLY",
      "MONTHLY",
      "TOTAL"
    ],
    "batch_size": 1000
  },
  "ads_user_funnel": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_user_funnel_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/user_funnel_1d"
  },
  "ads_user_retention": {
    "register_source_table": "dwd.dwd_user_event_wide_di",
    "active_source_table": "dws.dws_user_action_1d",
    "target_table": "ads.ads_user_retention",
    "sink_path": "hdfs:///warehouse/movie/ads/user_retention",
    "retention_days": [1, 7, 30]
  },
  "ads_genre_preference": {
    "source_table": "dws.dws_movie_action_1d",
    "target_table": "ads.ads_genre_preference_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/genre_preference_1d",
    "top_n": 100
  },
  "ads_itemcf": {
    "source_table": "dws.dws_user_item_preference_1d",
    "source_type": "user_item_preference",
    "target_table": "ads.ads_itemcf_similar_movies",
    "sink_path": "hdfs:///warehouse/movie/ads/itemcf_similar_movies",
    "lookback_days": 90,
    "min_user_item_score": 0.1,
    "min_co_users": 2,
    "shrinkage": 10.0,
    "top_k_similar": 100,
    "event_score_weights": {
      "view": 1.0,
      "favorite_add": 2.0,
      "favorite_remove": -1.0,
      "comment": 2.0,
      "rating": 3.0,
      "watched": 3.0,
      "rating_value": 2.0
    }
  },
  "ads_als_similar_movies": {
    "source_table": "dws.dws_user_item_preference_1d",
    "target_table": "ads.ads_itemcf_similar_movies",
    "sink_path": "hdfs:///warehouse/movie/ads/itemcf_similar_movies",
    "similarity_type": 3,
    "top_k_similar": 50,
    "min_similarity_score": 0.05,
    "min_user_positive_items": 2,
    "min_item_positive_users": 5,
    "positive_score_weights": {
      "view_cnt": 0.2,
      "rating_cnt": 1.0,
      "rating_avg_bonus": 0.5,
      "comment_cnt": 1.0,
      "favorite_add_cnt": 2.0,
      "watched_cnt": 3.0
    },
    "score_transform": {
      "method": "log1p",
      "scale": 1.0
    },
    "als_params": {
      "rank": 64,
      "max_iter": 10,
      "reg_param": 0.05,
      "alpha": 30.0,
      "seed": 20260329
    },
    "pairing": {
      "strategy": "exact_block_join",
      "block_count": 16
    }
  },
  "ads_itemcf_similar_movies_postgres_sync": {
    "source_table": "ads.ads_itemcf_similar_movies",
    "target_table": "public.stats_similar_movies",
    "supported_similarity_types": [
      2,
      3
    ],
    "batch_size": 1000
  },
  "ads_search_keyword_insights": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_search_keyword_insights_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/search_keyword_insights_1d",
    "top_n": 200,
    "min_search_cnt": 5
  },
  "ads_search_funnel": {
    "source_table": "dwd.dwd_user_event_wide_di",
    "target_table": "ads.ads_search_funnel_1d",
    "sink_path": "hdfs:///warehouse/movie/ads/search_funnel_1d"
  }
}
