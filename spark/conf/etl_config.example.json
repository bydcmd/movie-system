{
  "spark": {
    "app_name_batch": "movie-compact-warehouse",
    "master": "yarn",
    "warehouse_dir": "hdfs:///warehouse/tablespace/external/hive",
    "shuffle_partitions": 400
  },
  "postgres": {
    "jdbc_url": "jdbc:postgresql://127.0.0.1:5432/movie",
    "user": "movie_user",
    "password": "movie_password",
    "driver": "org.postgresql.Driver",
    "fetch_size": 10000,
    "tables": [
      {
        "source_table": "public.movies",
        "partition_column": "movie_id",
        "lower_bound": 1,
        "upper_bound": 2000000,
        "num_partitions": 24
      },
      {
        "source_table": "public.users"
      },
      {
        "source_table": "public.ratings"
      },
      {
        "source_table": "public.comments"
      },
      {
        "source_table": "public.comment_likes"
      },
      {
        "source_table": "public.favorite_folders"
      },
      {
        "source_table": "public.favorites"
      },
      {
        "source_table": "public.view_history"
      },
      {
        "source_table": "public.watched_movies"
      }
    ]
  },
  "dw_event_fact": {
    "source_mode": "jdbc",
    "source_tables": {
      "users": "public.users",
      "movies": "public.movies",
      "comments": "public.comments",
      "favorite_folders": "public.favorite_folders",
      "ratings": "public.ratings",
      "comment_likes": "public.comment_likes",
      "favorites": "public.favorites",
      "view_history": "public.view_history",
      "watched_movies": "public.watched_movies"
    },
    "target_table": "dw.dw_user_event_fact_di",
    "sink_path": "hdfs:///warehouse/movie/dw/user_event_fact_di"
  },
  "dw_source_generator": {
    "movie_limit": 500,
    "user_target": 300,
    "new_user_target": 30,
    "folder_target": 450,
    "view_target": 8000,
    "rating_target": 2500,
    "comment_target": 1500,
    "comment_like_target": 2500,
    "favorite_target": 2000,
    "watched_target": 1800,
    "sample_ratio": 0.35,
    "lookback_days": 90,
    "seed": 20260412,
    "jdbc_query_limit_cap": 20000
  },
  "dm_hot_movies": {
    "source_table": "dw.dw_user_event_fact_di",
    "source_type": "event_fact",
    "event_source_table": "dw.dw_user_event_fact_di",
    "total_source_table": "dw.dw_user_event_fact_di",
    "total_source_type": "event_fact",
    "target_table": "dm.dm_hot_movies",
    "sink_path": "hdfs:///warehouse/movie/dm/hot_movies",
    "period_days": {
      "DAILY": 1,
      "WEEKLY": 7,
      "MONTHLY": 30,
      "TOTAL": null
    },
    "top_n": 100,
    "hot_score_weights": {
      "view_pv": 1.0,
      "view_uv": 1.5,
      "rating_cnt": 2.0,
      "comment_cnt": 2.0,
      "comment_like_cnt": 0.8,
      "favorite_add_cnt": 1.2,
      "favorite_remove_cnt": -0.8,
      "watched_cnt": 2.5,
      "active_user_cnt": 1.0
    }
  },
  "dm_hot_movies_postgres_sync": {
    "source_table": "dm.dm_hot_movies",
    "target_table": "public.stats_hot_movies",
    "supported_period_types": [
      "DAILY",
      "WEEKLY",
      "MONTHLY",
      "TOTAL"
    ],
    "batch_size": 1000
  },
  "dm_user_retention": {
    "register_source_table": "dw.dw_user_event_fact_di",
    "target_table": "dm.dm_user_retention",
    "sink_path": "hdfs:///warehouse/movie/dm/user_retention",
    "retention_days": [
      1,
      7,
      30
    ]
  },
  "dm_genre_preference": {
    "source_table": "dm.dm_hot_movies",
    "event_source_table": "dw.dw_user_event_fact_di",
    "metric_period_type": "DAILY",
    "target_table": "dm.dm_genre_preference_1d",
    "sink_path": "hdfs:///warehouse/movie/dm/genre_preference_1d",
    "top_n": 100
  },
  "dm_user_retention_postgres_sync": {
    "source_table": "dm.dm_user_retention",
    "target_table": "public.stats_user_retention",
    "batch_size": 1000
  },
  "dm_genre_preference_postgres_sync": {
    "source_table": "dm.dm_genre_preference_1d",
    "target_table": "public.stats_genre_preference_1d",
    "batch_size": 1000
  }
}
