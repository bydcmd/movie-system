<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.movie.backend.mapper.PersonMapper">

    <resultMap id="BaseResultMap" type="com.movie.backend.entity.Person">
        <id column="person_id" property="id" />
        <result column="name" property="name" />
        <result column="sex" property="sex" />
        <result column="name_en" property="nameEn" />
        <result column="name_zh" property="nameZh" />
        <result column="birth" property="birth" />
        <result column="birthplace" property="birthplace" />
        <result column="profession" property="profession" />
        <result column="biography" property="biography" />
        <result column="person_avatar" property="avatar" />
    </resultMap>

    <sql id="Base_Column_List">
        person_id, name, sex, name_en, name_zh, birth, birthplace, profession, biography, person_avatar
    </sql>

    <insert id="insert" parameterType="com.movie.backend.entity.Person">
        INSERT INTO persons (person_id, name, sex, name_en, name_zh, birth, birthplace, profession, biography, person_avatar)
        VALUES (#{id}, #{name}, #{sex}, #{nameEn}, #{nameZh}, #{birth}, #{birthplace}, #{profession}, #{biography}, #{avatar})
    </insert>

    <update id="update" parameterType="com.movie.backend.entity.Person">
        UPDATE persons
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="sex != null">sex = #{sex},</if>
            <if test="nameEn != null">name_en = #{nameEn},</if>
            <if test="nameZh != null">name_zh = #{nameZh},</if>
            <if test="birth != null">birth = #{birth},</if>
            <if test="birthplace != null">birthplace = #{birthplace},</if>
            <if test="profession != null">profession = #{profession},</if>
            <if test="biography != null">biography = #{biography},</if>
            <if test="avatar != null">person_avatar = #{avatar},</if>
        </set>
        WHERE person_id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM persons WHERE person_id = #{id}
    </delete>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM persons WHERE person_id = #{id}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM persons
        <where>
            <if test="keyword != null and keyword != ''">
                AND (name LIKE '%' || #{keyword} || '%' OR name_en LIKE '%' || #{keyword} || '%')
            </if>
        </where>
    </select>
</mapper>
