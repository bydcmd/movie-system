<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.movie.backend.mapper.ViewHistoryMapper">

    <insert id="insert" parameterType="com.movie.backend.entity.ViewHistory">
        INSERT INTO view_history (user_id, movie_id, view_time)
        VALUES (#{userId}, #{movieId}, #{viewTime})
    </insert>

    <select id="selectHistoryByUserId" resultMap="MovieItemVOMap">
        SELECT
            m.movie_id,
            m.name,
            m.cover,
            m.douban_score as score,
            m.douban_votes as votes,
            m.genres,
            m.year,
            m.directors,
            m.actors,
            m.regions,
            m.mins,
            m.storyline,
            TO_CHAR(vh.view_time, 'YYYY-MM-DD HH24:MI:SS') as favorite_time
        FROM movies m
        JOIN view_history vh ON m.movie_id = vh.movie_id
        WHERE vh.user_id = #{userId}
        ORDER BY vh.view_time DESC
    </select>

    <resultMap id="MovieItemVOMap" type="com.movie.backend.dto.MovieItemVO">
        <result column="movie_id" property="movieId" />
        <result column="name" property="movieName" />
        <result column="cover" property="cover" />
        <result column="score" property="score" />
        <result column="votes" property="votes" />
        <result column="genres" property="genres" />
        <result column="year" property="year" />
        <result column="directors" property="directors" typeHandler="com.movie.backend.config.JsonTypeHandler" />
        <result column="actors" property="actors" typeHandler="com.movie.backend.config.JsonTypeHandler" />
        <result column="regions" property="regions" />
        <result column="mins" property="mins" />
        <result column="storyline" property="storyline" />
        <result column="favorite_time" property="favoriteTime" />
    </resultMap>

    <select id="selectByUserAndMovie" resultType="com.movie.backend.entity.ViewHistory">
        SELECT history_id as id, user_id as userId, movie_id as movieId, view_time as viewTime
        FROM view_history 
        WHERE user_id = #{userId} AND movie_id = #{movieId}
        LIMIT 1
    </select>

    <delete id="deleteById">
        DELETE FROM view_history WHERE history_id = #{id}
    </delete>

    <delete id="deleteBatchByIds">
        DELETE FROM view_history
        WHERE user_id = #{userId}
        AND history_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteAllByUserId">
        DELETE FROM view_history WHERE user_id = #{userId}
    </delete>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM view_history WHERE user_id = #{userId}
    </select>

    <update id="updateViewTime">
        UPDATE view_history 
        SET view_time = NOW()
        WHERE user_id = #{userId} AND movie_id = #{movieId}
    </update>

    <delete id="deleteByMovieId">
        DELETE FROM view_history
        WHERE movie_id = #{movieId}
    </delete>
</mapper>
