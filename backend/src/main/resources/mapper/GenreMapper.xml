<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.movie.backend.mapper.GenreMapper">

    <resultMap id="BaseResultMap" type="com.movie.backend.entity.Genre">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="name_en" property="nameEn" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, name_en, description, create_time
    </sql>

    <!-- Select all genres -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM genres
        ORDER BY name ASC
    </select>

    <!-- Select genre by ID -->
    <select id="selectById" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM genres
        WHERE id = #{id}
    </select>

    <!-- Select genre by name -->
    <select id="selectByName" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM genres
        WHERE name = #{name}
    </select>

    <!-- Get genres by movie ID -->
    <select id="selectByMovieId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT g.id, g.name, g.name_en, g.description, g.create_time
        FROM genres g
        INNER JOIN movie_genre_relation mgr ON g.id = mgr.genre_id
        WHERE mgr.movie_id = #{movieId}
        ORDER BY g.name ASC
    </select>

    <!-- Insert genre -->
    <insert id="insert" parameterType="com.movie.backend.entity.Genre" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO genres (name, name_en, description)
        VALUES (#{name}, #{nameEn}, #{description})
    </insert>

    <!-- Update genre -->
    <update id="update" parameterType="com.movie.backend.entity.Genre">
        UPDATE genres
        SET name = #{name},
            name_en = #{nameEn},
            description = #{description}
        WHERE id = #{id}
    </update>

    <!-- Delete genre by ID -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM genres WHERE id = #{id}
    </delete>

</mapper>
